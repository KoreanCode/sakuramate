{
  "name": "ochess",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:server": "node server/main.mjs",
    "dev:full": "concurrently -n server,client -c cyan,magenta \"npm run dev:server\" \"npm run dev -- --port 5173\"",
    "start": "node server/main.mjs",
    "server": "node server/main.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "smoke:visual:install": "node scripts/install_visual_browser.mjs",
    "smoke:multi": "node scripts/multiplayer_smoke.mjs",
    "smoke:voice": "node scripts/voice_smoke.mjs",
    "smoke:visual": "node scripts/visual_smoke.mjs",
    "quality:visual": "npm run build && npm run smoke:visual"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.26",
    "@colyseus/sdk": "^0.17.43",
    "chess.js": "^1.4.0",
    "colyseus": "^0.17.10",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
